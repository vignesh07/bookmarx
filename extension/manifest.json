{
  "manifest_version": 3,
  "name": "Bookmarx Sync",
  "version": "0.2.0",
  "description": "Pull your X bookmarks into your local Bookmarx instance.",
  "permissions": ["cookies", "webRequest", "tabs", "declarativeNetRequest", "alarms"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*", "http://localhost/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Bookmarx"
  }
}
