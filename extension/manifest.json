{
  "manifest_version": 3,
  "name": "Bookmarx Sync",
  "version": "0.1.0",
  "description": "Pull your X bookmarks into your self-hosted Bookmarx instance.",
  "permissions": ["storage", "cookies"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Bookmarx"
  },
  "icons": {
    "128": "icon.png"
  }
}
